# Required: absolute path to this repo on NAS host filesystem
OBS_ROOT=/volume1/docker/home-observability

# Required: Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# Required: Pi-hole connections
PIHOLE1_HOST=http://192.168.1.10
PIHOLE1_PASSWORD=change-me
PIHOLE2_HOST=http://192.168.1.11
PIHOLE2_PASSWORD=change-me

# Optional: host port for cAdvisor UI/metrics (container port stays 8080)
CADVISOR_HOST_PORT=18080
